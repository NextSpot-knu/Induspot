# --- App Configuration ---
ENV=development
PROJECT_NAME="InduSpot API"

# --- Supabase Configuration ---
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT Secret: Supabase JWT 검증용 (Gotrue JWT Secret)
# Supabase Project settings -> API -> JWT Secret 에서 획득 가능
JWT_SECRET=your-supabase-jwt-secret

# --- Firestore (사용자 선호 벡터 저장소; Pinecone 대체) ---
# 8차원 선호 벡터를 user_id 로 저장/조회(KV). ADC 인증, 기본 DB 사용. 보통 기본값으로 충분.
FIRESTORE_DATABASE=(default)
FIRESTORE_COLLECTION=user_preference_vectors

# --- Kakao Mobility Directions API (선택) ---
# 설정 시 후보 시설까지 실거리/실시간 이동시간을 사용. 비우면 Haversine 직선거리 도보 환산으로 폴백.
KAKAO_REST_API_KEY=

# === GCP 공통 ===
GCP_PROJECT_ID=knudc-henryseo711

# --- WP1: Vertex AI Endpoint 혼잡 예측 서빙 ---
VERTEX_LOCATION=us-central1
# 배포된 Endpoint 숫자 ID. 비우면 WP1 비활성화(=GCS model.pkl 폴백 경로 사용).
# scripts/deploy_vertex.py 실행 후 출력되는 VERTEX_ENDPOINT_ID 를 넣는다.
VERTEX_ENDPOINT_ID=
VERTEX_TIMEOUT_SECONDS=5.0

# --- WP3: Gemini 추천 사유 생성 ---
# true 로 켜면 Vertex Gemini 호출, 실패/끄면 템플릿 폴백.
GEMINI_ENABLED=false
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=4.0

# --- WP2: BigQuery + BQML ---
BQ_DATASET=induspot
BQ_LOCATION=us-central1

# --- WP4: Pub/Sub 수집 백본 ---
PUBSUB_TOPIC=induspot-congestion
PUBSUB_PUSH_SUBSCRIPTION=induspot-congestion-push
# push OIDC 검증용(비우면 검증 생략, Cloud Run IAM 이 1차 방어). 운영 시 설정 권장.
PUBSUB_PUSH_SERVICE_ACCOUNT=
PUBSUB_PUSH_AUDIENCE=

# --- CORS Configuration ---
# 쉼표(,)로 구분된 허용 도메인 목록. 실제 도메인을 지정하면 해당 오리진만 허용 + credentials 활성(엄격 모드).
# "*" 또는 미설정이면 모든 오리진 허용(credentials 끔). 운영 환경에서는 실제 프런트 도메인 지정 권장.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
