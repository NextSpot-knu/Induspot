# --- Supabase Configuration ---
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Pinecone Configuration ---
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=induspot-poi-index

# --- Kakao Maps SDK ---
NEXT_PUBLIC_KAKAO_MAPS_APP_KEY=your-kakao-maps-app-key

# --- Firebase Authentication (관리자 로그인 — GCP 베이스, REST) ---
# Firebase 콘솔 > 프로젝트 설정 > 일반 > '웹 API 키'. (Authentication 에서 이메일/비밀번호 사용설정 + 관리자 user 추가 선행)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key

# --- FastAPI Configurations ---
FASTAPI_API_URL=http://localhost:8000
JWT_SECRET=your-supabase-jwt-secret
